<%= form_with(model: lunch_log, class: "pixel-form pixel-card") do |form| %>
  <% if lunch_log.errors.any? %>
    <div class="error-box">
      <h2>保存できませんでした</h2>
      <ul>
        <% lunch_log.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :visited_on, "行った日" %>
    <%= form.date_field :visited_on, autocomplete: "off" %>
  </div>

  <div>
    <%= form.label :shop_name, "店名" %>
    <%= form.text_field :shop_name, placeholder: "例: 渋谷の定食屋" %>
  </div>

  <div>
    <%= form.label :area, "エリア" %>
    <%= form.text_field :area, placeholder: "例: 道玄坂 / 宮益坂" %>
  </div>

  <div>
    <%= form.label :price, "価格" %>
    <%= form.number_field :price, inputmode: "numeric", placeholder: "例: 980" %>
  </div>

  <div class="range-field">
    <div class="range-field__label">
      <%= form.label :rating, "満足度" %>
      <span><%= lunch_log.rating.presence || 3 %>/5</span>
    </div>
    <%= form.range_field :rating, min: 1, max: 5 %>
  </div>

  <div>
    <%= form.label :crowdedness, "混雑度" %>
    <%= form.select :crowdedness, ["空いてる", "普通", "混んでる"] %>
  </div>

  <div class="check-line">
    <%= form.check_box :solo_friendly %>
    <%= form.label :solo_friendly, "一人で入りやすい？" %>
  </div>

  <div class="check-line">
    <%= form.check_box :repeat %>
    <%= form.label :repeat, "また行く？" %>
  </div>

  <div>
    <%= form.label :memo, "メモ" %>
    <%= form.text_area :memo, placeholder: "混み具合、席、また行きたい理由など" %>
  </div>

  <div class="form-actions">
    <%= form.submit lunch_log.persisted? ? "変更を保存" : "ランチを記録", class: "pixel-button pixel-button--full" %>
    <%= link_to "一覧へ戻る", lunch_logs_path, class: "text-link" %>
  </div>
<% end %>
