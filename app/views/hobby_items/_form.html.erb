<%= form_with(model: hobby_item, class: "pixel-form pixel-card") do |form| %>
  <% if hobby_item.errors.any? %>
    <div class="error-box">
      <h2>保存できませんでした</h2>
      <ul>
        <% hobby_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, "タイトル" %>
    <%= form.text_field :title, placeholder: "例: 週末ライブ / 読みたい本" %>
  </div>

  <div>
    <%= form.label :category, "カテゴリ" %>
    <%= form.text_field :category, placeholder: "ライブ、DJ、読書、技術" %>
  </div>

  <div>
    <%= form.label :item_type, "種類" %>
    <%= form.select :item_type, [["予定", "event"], ["メモ", "memo"]] %>
  </div>

  <div>
    <%= form.label :scheduled_on, "日付" %>
    <%= form.date_field :scheduled_on %>
  </div>

  <div>
    <%= form.label :location, "場所" %>
    <%= form.text_field :location, placeholder: "例: 渋谷 / 自宅" %>
  </div>

  <div>
    <%= form.label :cost, "費用" %>
    <%= form.number_field :cost, inputmode: "numeric", placeholder: "例: 3500" %>
  </div>

  <div>
    <%= form.label :url, "URL" %>
    <%= form.url_field :url, placeholder: "https://..." %>
  </div>

  <div>
    <%= form.label :body, "本文" %>
    <%= form.text_area :body, placeholder: "予定の詳細や感想をここに" %>
  </div>

  <div class="range-field">
    <div class="range-field__label">
      <%= form.label :rating, "評価" %>
      <span><%= hobby_item.rating.presence || 3 %>/5</span>
    </div>
    <%= form.range_field :rating, min: 1, max: 5 %>
  </div>

  <div>
    <%= form.label :status, "ステータス" %>
    <%= form.select :status, [["予定", "planned"], ["完了", "done"], ["保管", "archived"]] %>
  </div>

  <div class="form-actions">
    <%= form.submit hobby_item.persisted? ? "変更を保存" : "保存する", class: "pixel-button pixel-button--full" %>
    <%= link_to "一覧へ戻る", hobby_items_path, class: "text-link" %>
  </div>
<% end %>
