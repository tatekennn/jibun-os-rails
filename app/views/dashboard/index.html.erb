<% content_for :title, "自分OS" %>
<% month_fare = @month_paid_rides.sum(:fare) %>
<% work_done_count = [@work_day.check_in_confirmed?, @work_day.check_out_confirmed?].count(true) %>
<% latest_lunch = @recent_lunch_logs.first %>

<section class="page-head dashboard-head">
  <div>
    <p class="eyebrow">DASHBOARD</p>
    <h1>今日の管理</h1>
    <p><%= l(@today, format: :long) %></p>
  </div>
  <%= link_to "AIチャット", ai_chat_path, class: "ghost-button dashboard-head__chat" %>
</section>

<% if @reminder.present? %>
  <section class="reminder-banner focus-work">
    <span class="card-icon card-icon--work" aria-hidden="true"></span>
    <strong><%= @reminder %></strong>
  </section>
<% end %>

<section class="pixel-card focus-work">
  <h2>打刻チェック</h2>
  <div class="check-grid">
    <div class="check-tile">
      <span class="card-icon card-icon--work" aria-hidden="true"></span>
      <p>出勤</p>
      <strong class="<%= @work_day.check_in_confirmed? ? "ok" : "ng" %>"><%= status_chip(@work_day.check_in_confirmed?) %></strong>
      <%= button_to(@work_day.check_in_confirmed? ? "確認済み" : "出勤打刻した", confirm_check_in_work_days_path, method: :patch, class: "pixel-button pixel-button--green") %>
    </div>

    <div class="check-tile">
      <span class="card-icon card-icon--ride" aria-hidden="true"></span>
      <p>退勤</p>
      <strong class="<%= @work_day.check_out_confirmed? ? "ok" : "ng" %>"><%= status_chip(@work_day.check_out_confirmed?) %></strong>
      <%= button_to(@work_day.check_out_confirmed? ? "確認済み" : "退勤打刻した", confirm_check_out_work_days_path, method: :patch, class: "pixel-button pixel-button--blue") %>
    </div>
  </div>
</section>

<section class="pixel-card focus-budget">
  <p class="eyebrow"><%= Date.current.year %>年<%= Date.current.month %>月</p>
  <h2>有料列車</h2>
  <div class="metric-grid">
    <div>
      <span>今月の合計</span>
      <strong><%= yen(month_fare) %></strong>
    </div>
    <div>
      <span>記録数</span>
      <strong><%= @month_paid_rides.count %>件</strong>
    </div>
  </div>
  <p class="card-note">年間換算 <%= yen(month_fare * 12) %></p>
  <div class="inline-actions">
    <%= link_to "列車ログ", paid_rides_path %>
    <%= link_to "今日乗った", new_paid_ride_path %>
  </div>
</section>

<section class="pixel-card">
  <h2>今日の項目</h2>
  <div class="status-row">
    <strong>打刻</strong>
    <span><%= work_done_count %>/2</span>
  </div>
  <div class="status-row">
    <strong>ランチ</strong>
    <span><%= latest_lunch ? latest_lunch.shop_name : "未記録" %></span>
  </div>
  <div class="status-row">
    <strong>次の趣味</strong>
    <span><%= @next_hobby_item ? short_date(@next_hobby_item.scheduled_on) : "未定" %></span>
  </div>
</section>

<section class="pixel-card">
  <h2>ショートカット</h2>
  <nav class="shortcut-grid" aria-label="ホームショートカット">
    <%= link_to "AI", ai_chat_path %>
    <%= link_to "打刻", today_work_days_path %>
    <%= link_to "列車", paid_rides_path %>
    <%= link_to "ランチ", lunch_logs_path %>
    <%= link_to "趣味", hobby_items_path %>
  </nav>
</section>
