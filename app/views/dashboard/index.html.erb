<% content_for :title, "自分OS" %>
<% month_fare = @month_paid_rides.sum(:fare) %>
<% work_done_count = [@work_day.check_in_confirmed?, @work_day.check_out_confirmed?].count(true) %>
<% latest_lunch = @recent_lunch_logs.first %>
<% work_next_label = @work_day.check_in_confirmed? ? (@work_day.check_out_confirmed? ? "今日は打刻完了" : "退勤だけ忘れずに") : "まず出勤打刻" %>
<% train_note = @month_paid_rides.any? ? "今月 #{@month_paid_rides.count}回 / #{yen(month_fare)}" : "今月はまだ記録なし" %>
<% lunch_note = latest_lunch ? "最近: #{latest_lunch.shop_name}" : "良かった店を1件残す" %>
<% diary_note = @recent_diary_entry ? "最新: #{short_date(@recent_diary_entry.wrote_on)} #{@recent_diary_entry.display_title}" : "今日のことを3行だけ" %>
<% hobby_note = @next_hobby_item ? "次: #{short_date(@next_hobby_item.scheduled_on)} #{@next_hobby_item.title}" : (@recent_hobby_memo ? "メモ: #{@recent_hobby_memo.title}" : "予定・メモを置く") %>
<% check_in_button_class = ["life-home__action-button", ("is-done" if @work_day.check_in_confirmed?)].compact.join(" ") %>
<% check_out_button_class = ["life-home__action-button", (@work_day.check_out_confirmed? ? "is-done" : "is-secondary")].compact.join(" ") %>

<section class="life-home" aria-label="自分OS ホーム">
  <header class="life-home__hero">
    <div class="life-home__hero-copy">
      <p class="life-home__eyebrow">TODAY / <%= l(@today, format: :long) %></p>
      <h1>今日を軽く回す</h1>
      <p>打刻・移動費・ランチ・趣味を、迷わず1タップで整理するホーム。</p>
    </div>
    <%= link_to "AIに相談", ai_chat_path, class: "life-home__ai-button" %>
  </header>

  <% if @reminder.present? %>
    <section class="life-home__notice" aria-label="リマインド">
      <span aria-hidden="true"></span>
      <strong><%= @reminder %></strong>
    </section>
  <% end %>

  <section class="life-home__primary-card" aria-labelledby="work-check-heading">
    <div>
      <p class="life-home__eyebrow">NEXT ACTION</p>
      <h2 id="work-check-heading"><%= work_next_label %></h2>
      <p><%= work_done_count %>/2 完了。毎日使う打刻を最上段に固定。</p>
    </div>

    <div class="life-home__work-actions">
      <%= button_to(@work_day.check_in_confirmed? ? "出勤済み" : "出勤した", confirm_check_in_work_days_path, method: :patch, class: check_in_button_class) %>
      <%= button_to(@work_day.check_out_confirmed? ? "退勤済み" : "退勤した", confirm_check_out_work_days_path, method: :patch, class: check_out_button_class) %>
    </div>
  </section>

  <section class="life-home__module-grid" aria-label="生活ログ">
    <%= link_to paid_rides_path, class: "life-home__module life-home__module--train" do %>
      <span>TRAIN</span>
      <strong>有料列車</strong>
      <small><%= train_note %></small>
    <% end %>

    <%= link_to lunch_logs_path, class: "life-home__module life-home__module--lunch" do %>
      <span>LUNCH</span>
      <strong>渋谷ランチ</strong>
      <small><%= lunch_note %></small>
    <% end %>

    <%= link_to hobby_items_path, class: "life-home__module life-home__module--hobby" do %>
      <span>HOBBY</span>
      <strong>趣味メモ</strong>
      <small><%= hobby_note %></small>
    <% end %>

    <%= link_to diary_entries_path, class: "life-home__module life-home__module--diary" do %>
      <span>DIARY</span>
      <strong>日記</strong>
      <small><%= diary_note %></small>
    <% end %>
  </section>

  <section class="life-home__quick-list" aria-label="すぐ使う">
    <div class="life-home__section-title">
      <h2>すぐ使う</h2>
      <span>記録先を迷わない</span>
    </div>

    <%= link_to today_work_days_path, class: "life-home__quick-row" do %>
      <span class="life-home__quick-icon">勤</span>
      <strong>打刻チェック</strong>
      <em><%= work_done_count %>/2</em>
    <% end %>

    <%= link_to new_paid_ride_path, class: "life-home__quick-row" do %>
      <span class="life-home__quick-icon">￥</span>
      <strong>有料列車を記録</strong>
      <em>追加</em>
    <% end %>

    <%= link_to new_lunch_log_path, class: "life-home__quick-row" do %>
      <span class="life-home__quick-icon">昼</span>
      <strong>ランチを残す</strong>
      <em>追加</em>
    <% end %>

    <%= link_to new_hobby_item_path, class: "life-home__quick-row" do %>
      <span class="life-home__quick-icon">趣</span>
      <strong>趣味予定・メモ</strong>
      <em>追加</em>
    <% end %>

    <%= link_to new_diary_entry_path, class: "life-home__quick-row" do %>
      <span class="life-home__quick-icon">日</span>
      <strong>日記を書く</strong>
      <em>追加</em>
    <% end %>
  </section>
</section>
