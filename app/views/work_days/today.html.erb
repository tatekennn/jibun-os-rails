<% content_for :title, "今日の打刻 - 自分OS" %>

<section class="page-head">
  <p class="eyebrow">WORK CHECK</p>
  <h1>今日の打刻</h1>
  <p><%= l(@work_day.date, format: :long) %></p>
</section>

<section class="pixel-card focus-work">
  <div class="check-grid">
    <div class="check-tile">
      <span class="card-icon card-icon--work" aria-hidden="true"></span>
      <p>出勤</p>
      <strong class="<%= @work_day.check_in_confirmed? ? "ok" : "ng" %>"><%= status_chip(@work_day.check_in_confirmed?) %></strong>
      <% if @work_day.check_in_confirmed_at %>
        <small><%= l(@work_day.check_in_confirmed_at, format: :short) %></small>
      <% end %>
      <%= button_to "出勤打刻した", confirm_check_in_work_days_path, method: :patch, class: "pixel-button pixel-button--green" %>
    </div>

    <div class="check-tile">
      <span class="card-icon card-icon--ride" aria-hidden="true"></span>
      <p>退勤</p>
      <strong class="<%= @work_day.check_out_confirmed? ? "ok" : "ng" %>"><%= status_chip(@work_day.check_out_confirmed?) %></strong>
      <% if @work_day.check_out_confirmed_at %>
        <small><%= l(@work_day.check_out_confirmed_at, format: :short) %></small>
      <% end %>
      <%= button_to "退勤打刻した", confirm_check_out_work_days_path, method: :patch, class: "pixel-button pixel-button--blue" %>
    </div>
  </div>
</section>

<section
  class="pixel-card work-reminder-card"
  data-controller="work-reminder"
  data-work-reminder-date-value="<%= @work_day.date.iso8601 %>"
  data-work-reminder-check-in-confirmed-value="<%= @work_day.check_in_confirmed? %>"
  data-work-reminder-check-out-confirmed-value="<%= @work_day.check_out_confirmed? %>"
>
  <div class="work-reminder-card__head">
    <div>
      <p class="eyebrow">REMINDER</p>
      <h2>打刻通知</h2>
      <p class="card-note">出勤・退勤の確認時刻を端末に通知します。</p>
    </div>
    <label class="switch-field">
      <input
        type="checkbox"
        data-work-reminder-target="enabled"
        data-action="work-reminder#toggle"
      >
      <span>ON</span>
    </label>
  </div>

  <div class="reminder-time-grid">
    <label>
      <span>出勤通知</span>
      <input
        type="time"
        value="09:30"
        data-work-reminder-target="checkInTime"
        data-action="change->work-reminder#saveFromForm"
      >
    </label>
    <label>
      <span>退勤通知</span>
      <input
        type="time"
        value="18:30"
        data-work-reminder-target="checkOutTime"
        data-action="change->work-reminder#saveFromForm"
      >
    </label>
  </div>

  <p class="reminder-status" data-work-reminder-target="status">OFF: 時刻を選んでONにできます。</p>
</section>

<section class="pixel-card">
  <h2>メモ</h2>
  <%= form_with model: @work_day, class: "pixel-form" do |form| %>
    <%= form.text_area :memo, rows: 5, placeholder: "今日は9時出勤で調整" %>
    <%= form.submit "保存", class: "pixel-button pixel-button--full" %>
  <% end %>
</section>

<%= link_to "履歴を見る", work_days_path, class: "text-link" %>
