<div id="<%= dom_id paid_ride %>">
  <p>
    <strong>Used on:</strong>
    <%= paid_ride.used_on %>
  </p>

  <p>
    <strong>Line name:</strong>
    <%= paid_ride.line_name %>
  </p>

  <p>
    <strong>Direction:</strong>
    <%= paid_ride.direction %>
  </p>

  <p>
    <strong>Fare:</strong>
    <%= paid_ride.fare %>
  </p>

  <p>
    <strong>Reason:</strong>
    <%= paid_ride.reason %>
  </p>

  <p>
    <strong>Fatigue level:</strong>
    <%= paid_ride.fatigue_level %>
  </p>

  <p>
    <strong>Memo:</strong>
    <%= paid_ride.memo %>
  </p>

</div>
